{{define "form_step_1_pt"}}
<div id="lead-form" class="form-card">
  <h3>1. O que descreve melhor voce?</h3>
  {{if .Error}}<p class="form-error">{{.Error}}</p>{{end}}
  <form hx-post="/form/1" hx-target="#lead-form" hx-swap="outerHTML">
    <input type="hidden" name="lang" value="{{.Lang}}">
    <input type="hidden" name="page_path" value="{{.PagePath}}">
    <input type="hidden" name="utm_source" value="{{.UTM.Source}}">
    <input type="hidden" name="utm_medium" value="{{.UTM.Medium}}">
    <input type="hidden" name="utm_campaign" value="{{.UTM.Campaign}}">
    <input type="hidden" name="utm_term" value="{{.UTM.Term}}">
    <input type="hidden" name="utm_content" value="{{.UTM.Content}}">
    <label><input type="radio" name="choice" value="Consultor, advisor ou fractional"> Consultor, advisor ou fractional</label>
    <label><input type="radio" name="choice" value="Fundador de negocio de servicos"> Fundador de negocio de servicos</label>
    <label><input type="radio" name="choice" value="Executivo ou lider em empresa"> Executivo ou lider em empresa</label>
    <label><input type="radio" name="choice" value="Especialista senior"> Especialista senior</label>
    <label><input type="radio" name="choice" value="Outro"> Outro</label>
    <input type="text" name="other" placeholder="Se marcou Outro, detalhe aqui">
    <button type="submit">Continuar</button>
  </form>
</div>
{{end}}

